---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StampCardPreview from '../components/StampCardPreview.astro';
import SignupForm from '../components/SignupForm.astro';
---
<Base title="Digitale Stempelkarte für dein Café">
  <Nav />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-latte text-espresso text-sm font-medium px-4 py-2 rounded-full mb-6">
        ☕ Kostenlos für Cafés
      </div>
      <h1 class="text-5xl md:text-6xl font-extrabold leading-tight mb-6">
        Die digitale Stempelkarte<br>
        <span class="text-caramel">für dein Café</span>
      </h1>
      <p class="text-lg text-espresso/70 max-w-xl mx-auto mb-10">
        Kein Papier. Kein Verlieren. Deine Kunden sammeln Punkte direkt auf dem Handy – du gewinnst treue Stammgäste.
      </p>
      <a href="#anmelden" class="inline-block bg-espresso text-cream font-semibold text-lg px-8 py-4 rounded-2xl hover:bg-caramel transition-colors duration-300">
        Jetzt kostenlos registrieren →
      </a>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 px-6 bg-latte/40">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white rounded-2xl p-6 shadow-sm">
        <div class="text-3xl mb-3">📱</div>
        <h3 class="font-bold text-lg mb-2">Immer dabei</h3>
        <p class="text-espresso/60 text-sm">Deine Kunden haben die Stempelkarte immer im Handy – kein Vergessen mehr.</p>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-sm">
        <div class="text-3xl mb-3">🎯</div>
        <h3 class="font-bold text-lg mb-2">Mehr Stammkunden</h3>
        <p class="text-espresso/60 text-sm">Belohnungssysteme sorgen dafür, dass Gäste immer wieder kommen.</p>
      </div>
      <div class="bg-white rounded-2xl p-6 shadow-sm">
        <div class="text-3xl mb-3">⚡</div>
        <h3 class="font-bold text-lg mb-2">In 5 Minuten live</h3>
        <p class="text-espresso/60 text-sm">Registrieren, fertig. Wir kümmern uns um alles andere.</p>
      </div>
    </div>
  </section>

  <!-- Card Preview -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <h2 class="text-3xl font-bold mb-3">So sieht es aus</h2>
      <p class="text-espresso/60">Eine saubere, moderne Karte – personalisiert mit deinem Café-Namen.</p>
    </div>
    <StampCardPreview cafeName="Café Beispiel" stampsTotal={10} stampsEarned={3} />
  </section>

  <!-- Signup -->
  <section id="anmelden" class="py-20 px-6 bg-espresso">
    <div class="max-w-lg mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-cream mb-3">Jetzt kostenlos anmelden</h2>
        <p class="text-cream/50">Wir melden uns innerhalb von 24h bei dir.</p>
      </div>
      <SignupForm apiEndpoint="/api/submit.php" />
    </div>
  </section>

  <Footer />
</Base>
