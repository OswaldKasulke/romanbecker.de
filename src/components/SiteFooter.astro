---
const year = new Date().getFullYear();
---
<footer class="border-t border-white/[0.06] pt-16 pb-8 px-6 md:px-10 relative overflow-hidden">
  <div class="max-w-[1400px] mx-auto">

    <!-- 2 Columns -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-8 mb-16">

      <!-- Brand -->
      <div>
        <a href="/" class="text-lg font-semibold text-sand tracking-tight mb-4 inline-block">
          fuerte<span class="opacity-30">.</span>digital
        </a>
        <p class="text-sm text-sand/30 leading-relaxed max-w-[260px]">
          Digitalagentur für Kölner Gastronomen. Ein Projekt von
          <a href="https://colognebeats.com" target="_blank" rel="noopener" class="text-sand/40 hover:text-sand transition-colors">Colognebeats</a>.
        </p>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-[11px] uppercase tracking-[0.25em] font-medium text-sand/25 mb-5">Legal</h4>
        <nav class="flex flex-col gap-3">
          <a href="/impressum" class="text-sm text-sand/40 hover:text-sand transition-colors duration-300">Impressum</a>
          <a href="/datenschutz" class="text-sm text-sand/40 hover:text-sand transition-colors duration-300">Datenschutz</a>
        </nav>
      </div>

    </div>

    <!-- Copyright -->
    <div class="border-t border-white/[0.06] pt-6 text-center">
      <p class="text-xs text-sand/15">&copy; {year} fuerte.digital</p>
    </div>
  </div>

  <!-- Giant Text -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 text-[12vw] md:text-[10vw] font-black text-white/[0.02] leading-none whitespace-nowrap select-none pointer-events-none" aria-hidden="true">
    fuerte.digital
  </div>
</footer>
