---
---
<section id="kontakt" class="py-24 md:py-32 px-6 md:px-10">
  <div class="max-w-[700px] mx-auto">

    <!-- Header -->
    <div class="mb-14" data-reveal>
      <h2 class="font-serif text-heading text-sand/90 mb-4">Jetzt starten</h2>
      <p class="text-sand/40 text-base">Erzähl uns von deinem Restaurant. Wir melden uns innerhalb von 24 Stunden.</p>
    </div>

    <!-- Form -->
    <form id="contact-form" class="space-y-8" data-reveal>
      <!-- Name + Restaurant -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="group">
          <label class="block text-[11px] uppercase tracking-[0.2em] font-medium text-sand/30 mb-3">Name</label>
          <input
            type="text"
            name="name"
            required
            placeholder="Dein Name"
            class="w-full bg-transparent border-b border-white/[0.08] pb-3 text-sand placeholder:text-sand/20 focus:border-orange/50 focus:outline-none transition-colors duration-300"
          />
        </div>
        <div class="group">
          <label class="block text-[11px] uppercase tracking-[0.2em] font-medium text-sand/30 mb-3">Restaurant</label>
          <input
            type="text"
            name="restaurant"
            required
            placeholder="Name deines Restaurants"
            class="w-full bg-transparent border-b border-white/[0.08] pb-3 text-sand placeholder:text-sand/20 focus:border-orange/50 focus:outline-none transition-colors duration-300"
          />
        </div>
      </div>

      <!-- E-Mail -->
      <div>
        <label class="block text-[11px] uppercase tracking-[0.2em] font-medium text-sand/30 mb-3">E-Mail</label>
        <input
          type="email"
          name="email"
          required
          placeholder="deine@email.de"
          class="w-full bg-transparent border-b border-white/[0.08] pb-3 text-sand placeholder:text-sand/20 focus:border-orange/50 focus:outline-none transition-colors duration-300"
        />
      </div>

      <!-- Nachricht -->
      <div>
        <label class="block text-[11px] uppercase tracking-[0.2em] font-medium text-sand/30 mb-3">Nachricht</label>
        <textarea
          name="message"
          rows="4"
          placeholder="Was können wir für dich tun?"
          class="w-full bg-transparent border-b border-white/[0.08] pb-3 text-sand placeholder:text-sand/20 focus:border-orange/50 focus:outline-none transition-colors duration-300 resize-none"
        ></textarea>
      </div>

      <!-- Submit -->
      <button
        id="submit-btn"
        type="submit"
        class="bg-orange text-white font-semibold text-sm px-8 py-3.5 rounded-full hover:bg-orange/85 active:scale-[0.98] transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Nachricht senden
      </button>
    </form>

    <!-- Success State (initially hidden) -->
    <div id="form-success" class="hidden py-10 text-center" data-reveal>
      <div class="w-12 h-px bg-orange mx-auto mb-6"></div>
      <p class="text-sand/80 text-base font-light">Danke! Wir melden uns innerhalb von 24 Stunden.</p>
    </div>

    <!-- Error State (initially hidden) -->
    <div id="form-error" class="hidden mt-4">
      <p class="text-orange/80 text-sm">
        Etwas ist schiefgelaufen.
        <a href="https://wa.me/4901705594140" target="_blank" rel="noopener noreferrer" class="underline hover:text-orange transition-colors">Schreib uns direkt auf WhatsApp.</a>
      </p>
    </div>

    <!-- Oder-Trenner -->
    <div class="flex items-center gap-4 my-12">
      <div class="flex-1 h-px bg-white/[0.06]"></div>
      <span class="text-[11px] uppercase tracking-[0.25em] text-sand/20 font-medium">Oder</span>
      <div class="flex-1 h-px bg-white/[0.06]"></div>
    </div>

    <!-- Alternative CTAs -->
    <div class="flex flex-col sm:flex-row gap-4" data-reveal>
      <a
        href="https://book.fuerte.digital"
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 text-center text-sm font-medium text-sand/60 border border-white/[0.08] px-6 py-3.5 rounded-full hover:border-white/[0.15] hover:text-sand transition-all duration-300"
      >
        Termin buchen
      </a>
      <a
        href="https://wa.me/4901705594140"
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 text-center text-sm font-medium text-sand/60 border border-white/[0.08] px-6 py-3.5 rounded-full hover:border-white/[0.15] hover:text-sand transition-all duration-300"
      >
        WhatsApp schreiben
      </a>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form');
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Wird gesendet…'; }
    errorEl?.classList.add('hidden');

    try {
      const response = await fetch('https://formspree.io/f/DEINE_FORM_ID', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: new FormData(form),
      });

      if (response.ok) {
        form.classList.add('hidden');
        successEl?.classList.remove('hidden');
      } else {
        errorEl?.classList.remove('hidden');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Nachricht senden'; }
      }
    } catch {
      errorEl?.classList.remove('hidden');
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Nachricht senden'; }
    }
  });
</script>
