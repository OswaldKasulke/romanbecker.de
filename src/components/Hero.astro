---
---
<section class="relative h-screen flex flex-col justify-end overflow-hidden px-6 md:px-10 pb-12 md:pb-16">

  <!-- Gradient Glows -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute top-[15%] left-[10%] w-[500px] h-[500px] bg-teal/30 rounded-full blur-[120px] animate-glow-pulse"
      data-parallax="0.2"
    ></div>
    <div
      class="absolute bottom-[20%] right-[5%] w-[400px] h-[400px] bg-plum/25 rounded-full blur-[100px] animate-glow-pulse"
      style="animation-delay: -3s;"
      data-parallax="0.4"
    ></div>
    <div
      class="absolute top-[40%] right-[30%] w-[200px] h-[200px] bg-orange/10 rounded-full blur-[80px] animate-float"
    ></div>
  </div>

  <div class="relative z-10 max-w-[1400px] mx-auto w-full">
    <!-- Headline -->
    <h1 class="text-display text-sand leading-[0.92] mb-8 md:mb-10">
      <span class="block">MEHR GÄSTE</span>
      <span class="block">FÜR DEIN</span>
      <span class="block">RESTAURANT.</span>
    </h1>

    <!-- Subtitle -->
    <p class="max-w-[480px] text-sand/70 text-base font-light leading-relaxed mb-8 md:mb-10">
      Bonuskarten, 360°-Touren und digitale Speisekarten — speziell für Kölner Gastronomen.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap items-center gap-4 mb-12 md:mb-14">
      <a
        href="#kontakt"
        class="bg-orange text-white font-semibold text-sm px-8 py-3.5 rounded-full hover:bg-orange/85 active:scale-[0.98] transition-all duration-300"
      >
        Kostenlos beraten
      </a>
      <a
        href="#services"
        class="text-sand/60 text-sm font-medium px-8 py-3.5 rounded-full border border-white/[0.1] hover:border-white/20 hover:text-sand/80 transition-all duration-300"
      >
        Mehr erfahren
      </a>
    </div>

    <!-- Scroll Indicator -->
    <div class="hidden md:flex flex-col items-center gap-3 text-sand/30 w-fit">
      <span class="text-[10px] uppercase tracking-[0.3em] font-medium">Scroll</span>
      <div class="w-px h-12 bg-gradient-to-b from-sand/30 to-transparent relative overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-4 bg-sand/60 animate-[scroll-line_2s_ease-in-out_infinite]"></div>
      </div>
    </div>
  </div>

  <style>
    @keyframes scroll-line {
      0% { transform: translateY(-100%); }
      100% { transform: translateY(400%); }
    }
  </style>
</section>
