# Roman Becker — URL-Routing
# Stand: 2026-05-08

RewriteEngine On

# 1) www. → non-www. (301)
#    Behebt Authority-Splitting zwischen www. und Root-Domain.
RewriteCond %{HTTP_HOST} ^www\.romanbecker\.de$ [NC]
RewriteRule ^(.*)$ https://romanbecker.de/$1 [R=301,L]

# 2) /<slug>/ → /<slug>.html (301)
#    Vorhandene Ordner (z.B. /marktanalyse/, /stadtteile/, /ratgeber/) bleiben unangetastet.
#    Bei allen anderen trailing-slash-URLs: 301 auf .html-Variante (existiert für alle Stadtteile + Ratgeber).
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1.html [R=301,L]
