# Roman Becker — URL-Routing
# Stand: 2026-05-11

Options -MultiViews

RewriteEngine On

# 1) www. → non-www. (301)
RewriteCond %{HTTP_HOST} ^www\.romanbecker\.de$ [NC]
RewriteRule ^(.*)$ https://romanbecker.de/$1 [R=301,L]

# 2) Spezifische Legacy-URLs (Google-indexierte URLs einer alten Site-Struktur)
RewriteRule ^evernest/?$ / [R=301,L]
RewriteRule ^eigenbedarfsklage/?$ /ratgeber/eigenbedarfsklage.html [R=301,L]
RewriteRule ^kontakt/?$ /#kontakt [R=301,L]
RewriteRule ^impressum/?$ /impressum.html [R=301,L]
RewriteRule ^linksammlung/?$ / [R=301,L]

# 3) Legacy: Top-Level-Slug der eigentlich ein Ratgeber ist → /ratgeber/<slug>.html
#    Beispiel: /annuitaetendarlehen/ → /ratgeber/annuitaetendarlehen.html
#    Cond: REQUEST_URI matcht /(.+)/$ UND /ratgeber/<slug>.html existiert
RewriteCond %{REQUEST_URI} ^/([^/]+)/$
RewriteCond %{DOCUMENT_ROOT}/ratgeber/%1.html -f
RewriteRule ^([^/]+)/$ /ratgeber/$1.html [R=301,L]

# 4) Generisch: /<slug>/ → /<slug>.html (für stadtteile/, ratgeber/ etc.)
#    Cond: .html-Variante im Document Root existiert (verhindert 404-Ketten)
RewriteCond %{REQUEST_URI} !\.html/?$
RewriteCond %{REQUEST_URI} ^/(.+)/$
RewriteCond %{DOCUMENT_ROOT}/%1.html -f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1.html [R=301,L]
