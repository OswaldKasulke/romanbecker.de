# Roman Becker — URL-Routing
# Stand: 2026-05-11

Options -MultiViews

# Lead-Backup-Log enthält personenbezogene Daten — nie öffentlich zugänglich machen
<Files "leads.log">
  Require all denied
</Files>

# Zeichensatz UTF-8 im HTTP-Header
AddDefaultCharset UTF-8
AddCharset UTF-8 .html .css .js .json .xml .txt

RewriteEngine On

# 1) www. → non-www. (301)
RewriteCond %{HTTP_HOST} ^www\.romanbecker\.de$ [NC]
RewriteRule ^(.*)$ https://romanbecker.de/$1 [R=301,L]

# Nießbrauch-Seiten: alte Einfach-s-Slugs -> korrekte Doppel-s-Slugs (301)
RewriteRule ^ratgeber/niesbrauch-wohnrecht\.html$      /ratgeber/niessbrauch-wohnrecht.html      [R=301,L]
RewriteRule ^ratgeber/niesbrauch-kapitalisieren\.html$ /ratgeber/niessbrauch-kapitalisieren.html [R=301,L]

# 2) Legacy-URLs einer alten Site-Struktur (vor /ratgeber/-Prefix-Umstellung)
#    Ziele thematisch gewählt für vollen Authority-Transfer + UX.
#    Mapping wird auf Basis Search-Console-Daten gepflegt (gepullt 2026-05-11).
#    Wenn weitere Legacy-URLs in GSC-Pull auftauchen, hier eintragen.

# --- Top-Level-Sonderfälle (kein /ratgeber/-Pendant) ---
RewriteRule ^evernest/?$               /#ueber-evernest                                  [R=301,L]
RewriteRule ^kontakt/?$                /#kontakt                                         [R=301,L]
RewriteRule ^impressum/?$              /impressum.html                                   [R=301,L]
RewriteRule ^linksammlung/?$           /ratgeber/                                        [R=301,L]

# --- Alte Top-Level-Ratgeber-URLs → neue /ratgeber/-Struktur ---
RewriteRule ^annuitaetendarlehen/?$    /ratgeber/annuitaetendarlehen.html               [R=301,L]
RewriteRule ^abschreibung-bei-immobilien/?$ /ratgeber/abschreibung-bei-immobilien.html  [R=301,L]
RewriteRule ^eigenbedarfsklage/?$      /ratgeber/eigenbedarfsklage.html                 [R=301,L]

# --- eigenbedarfsklage-2 wurde in eigenbedarfsklage.html zusammengeführt (2026-07-05) ---
RewriteRule ^ratgeber/eigenbedarfsklage-2\.html$ /ratgeber/eigenbedarfsklage.html       [R=301,L]

# --- heizungsgesetz + gebaeudeenergiegesetz in heizungsgesetz-aenderung.html zusammengeführt (2026-07-14) ---
RewriteRule ^ratgeber/heizungsgesetz\.html$        /ratgeber/heizungsgesetz-aenderung.html [R=301,L]
RewriteRule ^ratgeber/gebaeudeenergiegesetz\.html$ /ratgeber/heizungsgesetz-aenderung.html [R=301,L]
RewriteRule ^flurkarte/?$              /ratgeber/flurkarte.html                         [R=301,L]
RewriteRule ^notarkosten-beim-immobilienkauf/?$ /ratgeber/notarkosten-beim-immobilienkauf.html [R=301,L]
RewriteRule ^smart-heizung/?$          /ratgeber/smart-heizung.html                     [R=301,L]

# --- Catch-All: jeder Top-Level-Slug → /ratgeber/<slug>.html (wenn Datei existiert) ---
#     Deckt alle 30+ WP-Ratgeber-Seiten ab, ohne jede einzeln listen zu müssen.
RewriteCond %{REQUEST_URI} ^/([^/]+)/?$
RewriteCond %{DOCUMENT_ROOT}/ratgeber/%1.html -f
RewriteRule ^([^/]+)/?$ /ratgeber/$1.html [R=301,L]

# --- Catch-All: Top-Level-Slug → /<slug>.html im Root (wenn Datei existiert) ---
#     Fängt extensionslose Root-Seiten ab, z. B. /immobilienbewertung → /immobilienbewertung.html
#     -f-Check verhindert Loops und Fehl-Redirects; läuft nach dem /ratgeber/-Catch-All,
#     damit Ratgeber-Slugs weiterhin Vorrang haben.
RewriteCond %{REQUEST_URI} ^/([^/]+)/?$
RewriteCond %{DOCUMENT_ROOT}/%1.html -f
RewriteRule ^([^/]+)/?$ /$1.html [R=301,L]

# --- Interne WP-Testseite ---
RewriteRule ^startseite-alex/?$ / [R=301,L]

# 3) URL-Hygiene: trailing-slash → .html (Stadtteile + ratgeber/ Sub-Pfade)
#    Beispiel: /stadtteile/suelz/ → /stadtteile/suelz.html
#    Cond: .html-Variante im Document Root existiert (verhindert 404-Ketten)
RewriteCond %{REQUEST_URI} !\.html/?$
RewriteCond %{REQUEST_URI} ^/(.+)/$
RewriteCond %{DOCUMENT_ROOT}/%1.html -f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1.html [R=301,L]
